# 云端接收 API 环境变量说明
# 启动前: cp .env.example .env  然后按实际值修改

# MySQL (其他选项不变则只能改密码, 默认连本地回环在部署服务时配合 SSH tunnel 使用)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=wishwithyou
DB_NAME=dev_fireguard

# API 鉴权 token (生产必须设置, 空则放行仅限本地开发)
API_TOKEN=change-me-to-a-random-string

# API 监听端口
API_PORT=8000

# 证据图片存储目录 (Nginx 静态目录)
EVIDENCE_DIR=/data/fireguard/evidence

# 证据图片对外访问 URL 前缀 (Nginx 反代地址)
EVIDENCE_BASE_URL=http://8.140.28.233/evidence

# 上传限制 (MB)
MAX_UPLOAD_MB=10
